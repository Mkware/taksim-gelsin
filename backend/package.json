{
  "name": "taksim-gelsin-backend",
  "version": "1.0.0",
  "description": "Taksim Gelsin - Kırıkkale Taksi Çağırma Sistemi Backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src/ --ext .ts",
    "test": "vitest run",
    "test:load-matching": "RUN_MATCHING_LOAD_TEST=1 vitest run tests/load/matching_stress.test.ts --reporter=verbose",
    "check-migrations": "node scripts/check-migrations.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "firebase-admin": "^12.7.0",
    "google-auth-library": "^9.14.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jose": "^5.9.6",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "socket.io": "^4.7.5",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.4",
    "@testcontainers/redis": "^12.0.4",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.20.0",
    "eslint": "^10.7.0",
    "pg": "^8.22.0",
    "socket.io-client": "^4.8.3",
    "testcontainers": "^12.0.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
