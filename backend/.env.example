# ============================================================
# Taksim Gelsin Backend — örnek ortam değişkenleri
# Bu dosyayı .env olarak kopyalayıp GERÇEK değerleri girin.
# ASLA gerçek anahtarları bu örnek dosyaya yazmayın veya repoya commit etmeyin.
# ============================================================

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Supabase — Dashboard’dan Project URL + API keys
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# JWT — openssl rand -base64 48 ile iki AYRI gizli üretin (üretimde mutlaka farklı olsun)
JWT_ACCESS_SECRET=change_me_min_32_chars_access_secret_random_string
JWT_REFRESH_SECRET=change_me_min_32_chars_refresh_secret_different_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Redis (Upstash: REDIS_TLS=true, yerel: REDIS_TLS=false)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# Virgülle ayrılmış; üretimde yalnızca gerçek uygulama / panel origin’leri
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

GOOGLE_MAPS_API_KEY=

# Üretimde genelde warn veya error
LOG_LEVEL=info

# E.164, virgülle: +905551112233 (üretimde ZORUNLU — env şeması NODE_ENV=production iken doğrular)
ADMIN_PHONES=

# Tek satır JSON veya base64; Firebase Admin ile FCM gönderimi. iOS için ek şart: Firebase Console
# → Project settings → Cloud Messaging → Apple app: APNs Authentication Key (.p8) + Key ID + Team ID
# (eksikse messaging/third-party-auth-error). Ayrıntı: https://firebase.google.com/docs/cloud-messaging/ios/certs
FCM_SERVICE_ACCOUNT_JSON=

# Yerelde true olabilir; NODE_ENV=production iken false olmalıdır (aksi halde süreç başlamaz)
WALLET_CARD_SIMULATION_ENABLED=true

# Admin paneli “Loglar” sekmesi — PM2 veya başka out/error dosya yolları (boşsa log satırı dönmez)
ADMIN_LOG_OUT_PATH=
ADMIN_LOG_ERROR_PATH=

# searching kalan yolculuk bu dakikadan eskiyse otomatik iptal (deploy sonrası takılı aramalar)
STALE_SEARCHING_MINUTES=15

# Opsiyonel: eşleştirme / mesafe önbelleği
# MATCHING_ROAD_MATRIX_MAX_DRIVERS=10
# DRIVING_DISTANCE_CACHE_TTL_SEC=600
# Aynı anda kaç sürücüye teklif gönderilir (1-3; 1 = sıralı) — DB boşken bootstrap
# MATCHING_OFFER_WAVE_SIZE=1
# Yakındaki sürücü arama yarıçapı (m) — DB boşken bootstrap
# MATCHING_SEARCH_RADIUS_M=5000
# Yolculuk başına kuyruğa alınacak max sürücü sayısı — DB boşken bootstrap
# MATCHING_MAX_DRIVERS_PER_RIDE=5
# Kaç art arda timeout sonrası sürücü geçici bant dışı kalır — DB boşken bootstrap
# MATCHING_TIMEOUT_BAN_THRESHOLD=3
# Bant dışı kalma süresi (sn) — DB boşken bootstrap
# MATCHING_TIMEOUT_BAN_SECONDS=600
# Tahmini yolculuk ücreti üzerinden kabul komisyonu (%) — DB boşken bootstrap
# RIDE_ACCEPT_FEE_PERCENT=7

# Taksi tarifesi (TL) — DB boşken bootstrap; gerçek değer admin panelinden
# platform_settings'e yazılır, deploy gerekmez (bkz. platform_settings.service.ts)
# TARIFF_BASE_FARE=50
# TARIFF_PER_KM_RATE=50
# TARIFF_MINIMUM_FARE=150
# TARIFF_WAITING_RATE_PER_MINUTE=3

# Zorunlu güncelleme — bu sürümün altındaki mobil istemciler açılışta
# "güncelleme gerekli" kilidine düşer. 0.0.0 = kapalı. DB boşken bootstrap;
# gerçek değer admin panelinden (Platform Ayarları → Minimum uygulama sürümü)
# MIN_SUPPORTED_APP_VERSION=0.0.0
