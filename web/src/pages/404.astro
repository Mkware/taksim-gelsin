---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Sayfa bulunamadı" description="Aradığınız sayfa bulunamadı.">
  <section class="flex min-h-[50vh] items-center justify-center py-20">
    <div class="mx-auto max-w-md px-4 text-center sm:px-6">
      <p class="text-6xl font-extrabold text-primary">404</p>
      <h1 class="mt-4 text-2xl font-bold text-ink">Sayfa bulunamadı</h1>
      <p class="mt-3 text-muted">Aradığınız adres mevcut değil veya taşınmış olabilir.</p>
      <a href="/" class="btn-primary mt-8 inline-flex">Ana sayfaya dön</a>
    </div>
  </section>
</BaseLayout>
