---
import BaseLayout from '@/layouts/BaseLayout.astro';
import StoreBadges from '@/components/StoreBadges.astro';
import { siteConfig } from '@/config/site';

const features = [
  {
    icon: '📍',
    title: 'Nereden, nereye',
    body: 'Alış ve varış noktanızı seçin; tahmini ücreti görün ve talebinizi güvenle oluşturun.',
  },
  {
    icon: '🗺️',
    title: 'Canlı takip',
    body: 'Sürücünüz yola çıktığında haritadan izleyin; biniş kodunuz ile güvenli eşleşme sağlanır.',
  },
  {
    icon: '⚡',
    title: 'Hızlı eşleştirme',
    body: 'Yakındaki uygun sürücülere talebiniz iletilir; yanıt süresi platform ayarlarına göre yönetilir.',
  },
  {
    icon: '🛡️',
    title: 'Güvenli hesap',
    body: 'Telefon ile giriş, oturum güvenliği ve KVKK uyumlu veri işleme süreçleri.',
  },
];

const steps = [
  { n: '1', title: 'Uygulamayı açın', body: 'Hesap oluşturun veya giriş yapın.' },
  { n: '2', title: 'Güzergâhı belirleyin', body: 'Biniş ve varış noktasını seçin, ücret tahminini görün.' },
  { n: '3', title: 'Talep gönderin', body: 'Sistem uygun sürücüye yolculuk teklifini iletir.' },
  { n: '4', title: 'Yolculuğa çıkın', body: 'Canlı takip ve biniş kodu ile güvenli eşleşme.' },
];

const faq = [
  {
    q: 'Taksim Gelsin hangi bölgede hizmet veriyor?',
    a: `Şu an odak bölgemiz ${siteConfig.city}. Hizmet alanı genişledikçe bu sayfa güncellenecektir.`,
  },
  {
    q: 'Sürücü olarak nasıl kayıt olabilirim?',
    a: 'Sürücü hesapları uygulama içinde herkese açık kayıt ile açılmaz. Yetkili süreçler için Sürücüler sayfasına bakın.',
  },
  {
    q: 'Konum izni neden gerekli?',
    a: 'Taksi talebi ve canlı takip için konum bilgisi işlevsel bir gerekliliktir; izin verilmezse hizmet kısıtlanabilir.',
  },
  {
    q: 'Kişisel verilerim nasıl korunuyor?',
    a: 'KVKK aydınlatma metni ve gizlilik politikamızı web sitemizden veya uygulama içinden okuyabilirsiniz.',
  },
];
---

<BaseLayout>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-midnight text-white">
    <div
      class="pointer-events-none absolute -right-24 -top-24 h-80 w-80 rounded-full bg-primary/20 blur-3xl"
      aria-hidden="true"
    />
    <div class="relative mx-auto grid max-w-6xl items-center gap-10 px-4 py-16 sm:px-6 lg:grid-cols-2 lg:py-24">
      <div>
        <p class="inline-flex rounded-full bg-primary/15 px-3 py-1 text-xs font-bold uppercase tracking-wide text-primary">
          {siteConfig.city} taksi çağırma
        </p>
        <h1 class="mt-4 text-4xl font-extrabold leading-tight tracking-tight sm:text-5xl lg:text-6xl">
          {siteConfig.tagline}
        </h1>
        <p class="mt-5 max-w-xl text-base leading-relaxed text-white/75 sm:text-lg">
          {siteConfig.description}
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="#indir" class="btn-primary">Uygulamayı indir</a>
          <a href="#nasil-calisir" class="btn-secondary border-white/20 bg-transparent text-white hover:bg-white/10">
            Nasıl çalışır?
          </a>
        </div>
      </div>
      <div class="flex justify-center lg:justify-end">
        <div class="relative rounded-3xl border border-white/10 bg-midnight-elevated p-6 shadow-glow">
          <img
            src="/assets/brand_logo.png"
            alt={siteConfig.name}
            width="320"
            height="320"
            class="mx-auto h-48 w-48 rounded-2xl object-contain sm:h-64 sm:w-64"
          />
          <p class="mt-4 text-center text-sm font-semibold text-primary">Mobil uygulama ile kullanın</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="ozellikler" class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <h2 class="section-heading">Neden Taksim Gelsin?</h2>
      <p class="section-sub">Yolculuğunuzu baştan sona uygulama üzerinden yönetin.</p>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          features.map((f) => (
            <article class="rounded-2xl border border-border bg-white p-6 shadow-card transition hover:-translate-y-0.5 hover:shadow-lg">
              <span class="text-3xl" aria-hidden="true">
                {f.icon}
              </span>
              <h3 class="mt-4 text-lg font-bold text-ink">{f.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-muted">{f.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section id="nasil-calisir" class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <h2 class="section-heading">Nasıl çalışır?</h2>
      <p class="section-sub">Dört adımda taksi talebi oluşturun.</p>
      <ol class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          steps.map((s) => (
            <li class="relative rounded-2xl border border-border bg-surface-muted p-6">
              <span class="flex h-10 w-10 items-center justify-center rounded-full bg-primary text-sm font-extrabold text-ink">
                {s.n}
              </span>
              <h3 class="mt-4 font-bold text-ink">{s.title}</h3>
              <p class="mt-2 text-sm text-muted">{s.body}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- Download -->
  <section id="indir" class="py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
      <h2 class="section-heading">Uygulamayı indirin</h2>
      <p class="section-sub mx-auto">
        Taksim Gelsin'i telefonunuza yükleyerek {siteConfig.city}'de taksi çağırmaya başlayın.
      </p>
      <div class="mt-8">
        <StoreBadges />
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="sss" class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <h2 class="section-heading text-center">Sık sorulan sorular</h2>
      <div class="mt-10 space-y-4">
        {
          faq.map((item) => (
            <details class="group rounded-2xl border border-border bg-surface-muted p-5 open:bg-white open:shadow-card">
              <summary class="cursor-pointer list-none font-bold text-ink [&::-webkit-details-marker]:hidden">
                {item.q}
              </summary>
              <p class="mt-3 text-sm leading-relaxed text-muted">{item.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
