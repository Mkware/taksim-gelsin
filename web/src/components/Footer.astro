---
import { siteConfig } from '@/config/site';

const legal = [
  { href: '/kvkk', label: 'KVKK aydınlatma' },
  { href: '/gizlilik', label: 'Gizlilik politikası' },
  { href: '/kullanim-kosullari', label: 'Kullanım koşulları' },
];

const links = [
  { href: '/surucu', label: 'Sürücüler' },
  { href: '/iletisim', label: 'İletişim' },
];
---

<footer class="border-t border-border bg-midnight text-white">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <div class="grid gap-10 md:grid-cols-3">
      <div>
        <div class="flex items-center gap-3">
          <img src="/assets/brand_logo.png" alt="" width="40" height="40" class="h-10 w-10 rounded-lg" />
          <span class="text-lg font-extrabold">{siteConfig.name}</span>
        </div>
        <p class="mt-4 text-sm leading-relaxed text-white/70">{siteConfig.description}</p>
      </div>

      <div>
        <h2 class="text-sm font-bold uppercase tracking-wider text-primary">Sayfalar</h2>
        <ul class="mt-4 space-y-2">
          {
            links.map((l) => (
              <li>
                <a href={l.href} class="text-sm text-white/80 transition hover:text-primary">
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h2 class="text-sm font-bold uppercase tracking-wider text-primary">Yasal</h2>
        <ul class="mt-4 space-y-2">
          {
            legal.map((l) => (
              <li>
                <a href={l.href} class="text-sm text-white/80 transition hover:text-primary">
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="mt-10 flex flex-col gap-2 border-t border-white/10 pt-8 text-xs text-white/50 sm:flex-row sm:items-center sm:justify-between">
      <p>© {new Date().getFullYear()} {siteConfig.name}. Tüm hakları saklıdır.</p>
      <p>Son güncelleme: {siteConfig.lastUpdated}</p>
    </div>
  </div>
</footer>
