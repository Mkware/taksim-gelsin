---
import { legalDisclaimer } from '@/content/legal';
import { siteConfig } from '@/config/site';

interface Props {
  title: string;
  body: string;
}

const { title, body } = Astro.props;
---

<section class="bg-surface-muted py-12 sm:py-16">
  <div class="mx-auto max-w-3xl px-4 sm:px-6">
    <h1 class="section-heading">{title}</h1>
    <p class="mt-2 text-sm text-muted">Son güncelleme: {siteConfig.lastUpdated}</p>
    <article class="prose-legal mt-8 rounded-2xl border border-border bg-white p-6 shadow-card sm:p-8">
      {body}
      <hr class="my-8 border-border" />
      {legalDisclaimer}
    </article>
  </div>
</section>
